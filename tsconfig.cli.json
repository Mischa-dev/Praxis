{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./out/cli",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"],
      "@profile/*": ["./profile/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/cli/**/*",
    "src/main/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/renderer",
    "src/preload"
  ]
}
